---
// Hero.astro component
---
<section class="relative overflow-hidden min-h-[calc(100vh-73px)] flex items-center py-20">
  <div class="mx-auto max-w-7xl px-6 relative z-10 w-full">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-8">
        <span class="font-mono text-xs text-neon-cyan tracking-wider">Università di Genova | Study Manifesto</span>
        <span class="h-px w-12 bg-neon-cyan/30"></span>
      </div>
      
      <h2 class="text-4xl md:text-6xl font-extrabold tracking-tight text-cyber-text mb-6">
        Software Platforms & 
        <span class="block mt-2 bg-gradient-to-r from-neon-cyan to-neon-emerald bg-clip-text text-transparent">
          Cybersecurity
        </span>
      </h2>
      
      <p class="text-lg md:text-xl text-cyber-muted leading-relaxed mb-10">
        Official curriculum track for the Master of Science (Laurea Magistrale) in Computer Engineering. Designed to cultivate specialized expertise in system validation, operations optimization, threat protection, and trustworthy artificial intelligence structures.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="#core" class="px-6 py-3 font-mono text-xs font-semibold tracking-wider text-cyber-bg bg-neon-cyan hover:opacity-90 rounded transition-all duration-300 shadow-[0_0_15px_rgba(var(--glow-color-rgb),0.15)] hover:shadow-[0_0_25px_rgba(var(--glow-color-rgb),0.25)]">
          Initialize Core Curriculum
        </a>
        <a href="https://servizionline.unige.it/unige/stampa_manifesto/MF/2025/11965.html" target="_blank" rel="noopener noreferrer" class="px-6 py-3 font-mono text-xs font-semibold tracking-wider text-cyber-text border border-cyber-border hover:border-neon-emerald/50 bg-cyber-card hover:bg-neon-emerald/5 rounded transition-all duration-300">
          View UniGe Manifesto
        </a>
      </div>
    </div>
  </div>
</section>
