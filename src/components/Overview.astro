---
// Overview.astro component
---
<section id="overview" class="py-36 border-t border-cyber-border relative">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xs text-neon-cyan">Section 00</span>
        <span class="h-px w-12 bg-neon-cyan/30"></span>
      </div>
      <h3 class="text-2xl md:text-4xl font-bold text-cyber-text tracking-wider mb-4">
        Program Overview
      </h3>
      <p class="max-w-2xl text-cyber-muted text-sm md:text-base">
        Key credits, core requirements, and scientific sectors defining the Software Platforms & Cybersecurity Master's curriculum.
      </p>
    </div>

    <!-- Stats / Metrics Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="flex flex-col gap-1 p-4 rounded border border-cyber-border bg-cyber-card/30 backdrop-blur-sm">
        <span class="font-mono text-xs text-cyber-muted tracking-widest">Total Credits</span>
        <span class="text-3xl font-bold text-neon-cyan font-mono">120 Cfu</span>
        <span class="text-sm text-cyber-muted">Full 2-Year Program Structure</span>
      </div>
      <div class="flex flex-col gap-1 p-4 rounded border border-cyber-border bg-cyber-card/30 backdrop-blur-sm">
        <span class="font-mono text-xs text-cyber-muted tracking-widest">Core Requirements</span>
        <span class="text-3xl font-bold text-neon-emerald font-mono">08 Core</span>
        <span class="text-sm text-cyber-muted">Required Academic Modules</span>
      </div>
      <div class="flex flex-col gap-1 p-4 rounded border border-cyber-border bg-cyber-card/30 backdrop-blur-sm">
        <span class="font-mono text-xs text-cyber-muted tracking-widest">Elective Tracks</span>
        <span class="text-3xl font-bold text-neon-cyan font-mono">04 Electives</span>
        <span class="text-sm text-cyber-muted">Custom Specializations</span>
      </div>
      <div class="flex flex-col gap-1 p-4 rounded border border-cyber-border bg-cyber-card/30 backdrop-blur-sm">
        <span class="font-mono text-xs text-cyber-muted tracking-widest">Scientific Sectors</span>
        <span class="text-3xl font-bold text-cyber-text font-mono">Ing-Inf/05</span>
        <span class="text-sm text-cyber-muted">Computer Engineering Foundations</span>
      </div>
    </div>
  </div>
</section>
