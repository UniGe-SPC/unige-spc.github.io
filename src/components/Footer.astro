---
// Footer.astro component
---
<footer id="status" class="border-t border-cyber-border bg-cyber-card/40 py-20 font-mono text-xs text-cyber-muted">
  <div class="mx-auto max-w-7xl px-6 flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-2">
        <span class="h-2 w-2 rounded-full bg-neon-cyan animate-pulse"></span>
        <span class="text-cyber-text font-bold">UniGe // Ingegneria Informatica</span>
      </div>
      <p class="text-cyber-muted/70">Software Platforms & Cybersecurity</p>
    </div>

    <div class="flex flex-wrap justify-center gap-8 text-cyber-muted">
      <a href="https://github.com/UniGe-SPC" target="_blank" rel="noopener noreferrer" class="hover:text-neon-cyan transition-colors">Organization</a>
      <a href="https://github.com/UniGe-SPC/unige-spc.github.io" target="_blank" rel="noopener noreferrer" class="hover:text-neon-cyan transition-colors">Repository</a>
      <span class="hover:text-neon-emerald transition-colors pointer-events-none">Manifesto: Mf/2025/11965</span>
      <span class="text-cyber-muted/50">© 2026 UniGe Computer Engineering.</span>
    </div>
  </div>
</footer>
