                <span class="font-mono text-[12px] font-bold text-neon-emerald bg-neon-emerald/5 px-2 py-0.5 rounded border border-neon-emerald/25 flex items-center gap-1">
                  <span>{subject.data.cfu}</span>
                  <span class="text-[9px] opacity-75 font-normal">CFU</span>
                </span>
              </div>

              {/* Title & Description */}
              <h4 class="text-lg font-bold text-cyber-text group-hover:text-neon-emerald transition-colors duration-300 min-h-[2.5rem] leading-snug mb-2">
                {subject.data.name}
              </h4>
              
              <div class="text-[15px] text-cyber-muted leading-relaxed line-clamp-5 mt-3">
                <subject.Content />
