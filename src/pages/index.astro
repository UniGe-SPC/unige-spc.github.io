        <a href="https://github.com/UniGe-SPC" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-cyber-muted hover:text-neon-cyan transition-colors flex items-center gap-1.5">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 16 16"><path d="M1.75 1.5a.75.75 0 0 0 0 1.5h.75v11.5c0 .138.112.25.25.25h3.5a.25.25 0 0 0 .25-.25V10.5A1.5 1.5 0 0 1 8 9a1.5 1.5 0 0 1 1.5 1.5v3.5c0 .138.112.25.25.25h3.5a.25.25 0 0 0 .25-.25V3h.75a.75.75 0 0 0 0-1.5H1.75ZM9 10.5V14H7v-3.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5ZM4 4.5A.5.5 0 0 1 4.5 4h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1Zm.5 3.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5h-1ZM10 4.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1Zm.5 3.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5h-1Z"/></svg>
          <span class="hidden sm:inline">Organization</span>
        </a>
        <a href="https://github.com/UniGe-SPC/unige-spc.github.io" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-cyber-muted hover:text-neon-cyan transition-colors flex items-center gap-1.5">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 16 16"><path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.35 3.12.88.01.64.01 1.25.01 1.42 0 .21-.15.46-.55.38A8.013 8.013 0 0 1 0 8c0-4.42 3.58-8 8-8z"/></svg>
          <span class="hidden sm:inline">GitHub</span>
        </a>
        
        <!-- Interactive Theme Switch Button -->
        <button 
          id="theme-toggle" 
          aria-label="Toggle Theme Mode" 
          class="relative flex h-8 w-8 items-center justify-center rounded border border-cyber-border bg-cyber-card text-cyber-text hover:border-neon-cyan hover:text-neon-cyan hover:shadow-[0_0_10px_rgba(var(--glow-color-rgb),0.15)] transition-all cursor-pointer"
