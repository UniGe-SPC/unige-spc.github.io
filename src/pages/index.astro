            <span class="absolute top-0 right-0 text-[10px] font-mono text-cyber-muted/30 pointer-events-none select-none p-1 leading-none">+</span >
            <span class="absolute bottom-0 left-0 text-[10px] font-mono text-cyber-muted/30 pointer-events-none select-none p-1 leading-none">+</span >
            <span class="absolute bottom-0 right-0 text-[10px] font-mono text-cyber-muted/30 pointer-events-none select-none p-1 leading-none">+</span >

            <div>
              {/* Top Row Meta */}
              <div class="flex items-center justify-between gap-2 mb-4">
                <span class="font-mono text-[11px] text-cyber-muted tracking-wider bg-cyber-bg/50 px-2 py-0.5 rounded border border-cyber-border/40 group-hover:border-neon-cyan/20 group-hover:text-cyber-text transition-all duration-300">
