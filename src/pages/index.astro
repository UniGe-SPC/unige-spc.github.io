---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Overview from '../components/Overview.astro';
import SubjectCard from '../components/SubjectCard.astro';
import Footer from '../components/Footer.astro';

// Fetch and render content collections
const allSubjects = await getCollection('subjects');

const subjectsWithContent = await Promise.all(
  allSubjects.map(async (subject) => {
    const { Content } = await render(subject);
    return {
      ...subject,
      Content,
    };
  })
);

const coreSubjects = subjectsWithContent
  .filter((s) => s.data.category === 'core')
  .sort((a, b) => a.data.semester.localeCompare(b.data.semester) || a.data.name.localeCompare(b.data.name));

const electiveSubjects = subjectsWithContent
  .filter((s) => s.data.category === 'elective')
  .sort((a, b) => a.data.semester.localeCompare(b.data.semester) || a.data.name.localeCompare(b.data.name));
---

<Layout title="UniGe Masters | Software Platforms & Cybersecurity">
  <!-- Top Navigation Header -->
  <Header />

  <!-- Hero Section -->
  <Hero />

  <!-- Program Overview Section -->
  <Overview />

  <!-- Core Subjects Grid Section -->
  <section id="core" class="py-36 border-t border-cyber-border bg-cyber-card/10 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-neon-cyan/[0.01] to-transparent pointer-events-none"></div>
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-4">
          <span class="font-mono text-xs text-neon-cyan">Section 01</span>
          <span class="h-px w-12 bg-neon-cyan/30"></span>
        </div>
        <h3 class="text-2xl md:text-4xl font-bold text-cyber-text tracking-wider mb-4">
          Core Curriculum
        </h3>
        <p class="max-w-2xl text-cyber-muted text-sm md:text-base">
          Mandatory academic units establishing robust knowledge in cybersecurity systems, hardware optimization, software design patterns, and machine learning methods.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {coreSubjects.map((subject) => (
          <SubjectCard subject={subject} />
        ))}
      </div>
    </div>
  </section>

  <!-- Electives Grid Section -->
  <section id="electives" class="py-36 border-t border-cyber-border relative">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-neon-emerald/[0.01] to-transparent pointer-events-none"></div>
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-4">
          <span class="font-mono text-xs text-neon-emerald">Section 02</span>
          <span class="h-px w-12 bg-neon-emerald/30"></span>
        </div>
        <h3 class="text-2xl md:text-4xl font-bold text-cyber-text tracking-wider mb-4">
          Elective Specializations
        </h3>
        <p class="max-w-2xl text-cyber-muted text-sm md:text-base">
          Academic tracks allowing students to focus on mobile vulnerabilities, cybercrime forensics, scalable parallel processing, and trustworthy artificial intelligence.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {electiveSubjects.map((subject) => (
          <SubjectCard subject={subject} />
        ))}
      </div>
    </div>
  </section>

  <!-- Clean Footer Section -->
  <Footer />

  <!-- Theme Toggle Client-Side Handler -->
  <script>
    const setupThemeToggle = () => {
      const toggle = document.getElementById('theme-toggle');
      const sunIcon = document.getElementById('theme-toggle-sun');
      const moonIcon = document.getElementById('theme-toggle-moon');
      
      const updateIcons = (isDark: boolean) => {
        if (isDark) {
          sunIcon?.classList.remove('hidden');
          moonIcon?.classList.add('hidden');
        } else {
          sunIcon?.classList.add('hidden');
          moonIcon?.classList.remove('hidden');
        }
      };

      const handleToggleClick = () => {
        const element = document.documentElement;
        element.classList.toggle("dark");
        
        const isDark = element.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        updateIcons(isDark);
      };
      
      // Determine initial state
      const isDark = document.documentElement.classList.contains("dark");
      updateIcons(isDark);
      
      // Bind event listener
      toggle?.addEventListener('click', handleToggleClick);
    };

    // Initialize logic
    setupThemeToggle();
    
    // Support Astro transitions if added in the future
    document.addEventListener('astro:after-swap', setupThemeToggle);
  </script>
</Layout>
